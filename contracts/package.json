{
  "name": "paygram-contracts",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:report": "hardhat test --verbose",
    "coverage": "hardhat coverage",
    "node": "hardhat node",
    "wallets:create": "hardhat run scripts/createWallets.ts",
    "wallets:fund": "hardhat run scripts/fundTesters.ts --network arbitrum",
    "wallets:fund:sepolia": "hardhat run scripts/fundTesters.ts --network arbitrumSepolia",
    "deploy:local": "hardhat run scripts/deploy.ts --network hardhat",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network arbitrumSepolia",
    "deploy:arb": "hardhat run scripts/deploy.ts --network arbitrum",
    "deploy:arb:rosca": "hardhat run scripts/deployRosca.ts --network arbitrum",
    "funding:check": "hardhat run scripts/checkFunding.ts --network arbitrum",
    "env:app": "hardhat run scripts/printAppEnv.ts",
    "rehearse:sepolia": "hardhat run scripts/liveRehearsal.ts --network arbitrumSepolia",
    "verify:invariants": "hardhat test test/invariants.noStuckFunds.ts",
    "verify:arb": "hardhat run scripts/verifyArb.ts --network arbitrum"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.8",
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.12",
    "@openzeppelin/contracts": "^5.2.0",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.17.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.7",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.18",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.14",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.6.3"
  }
}
