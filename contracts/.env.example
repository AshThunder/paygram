# Copy to contracts/.env — never commit real keys

# Funding wallet (from npm run wallets:create → .wallets/FUNDING_KEY.env.snippet)
FUNDING_PRIVATE_KEY=

# Optional override if hardhat signer should differ
# PRIVATE_KEY=

# RPCs (publicnode is a reliable public Arb One endpoint)
ARB_RPC_URL=https://arbitrum-one.publicnode.com
ARB_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# USDC — Arbitrum One mainnet is hardcoded in deploy.ts; Sepolia needs an address
# Arbitrum One native USDC: 0xaf88d065e77c8cC2239327C5EDb3A432268e5831
USDC_ADDRESS=

# Who can rescue *excess* (non-escrowed) tokens only
RESCUE_GUARDIAN=

# Fund split amounts when running wallets:fund
FUND_ETH_EACH=0.002
FUND_USDC_EACH=25
TEST_WALLET_COUNT=5

ARBISCAN_API_KEY=
REPORT_GAS=0
