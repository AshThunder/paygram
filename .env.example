# Telegram (shell bot)
TELEGRAM_BOT_TOKEN=
VITE_BOT_USERNAME=paygram_bbot
VITE_MINI_APP_URL=https://your-app.vercel.app

# Magic — email OTP login (Telegram is Mini App shell only, not an auth provider)
VITE_MAGIC_API_KEY=pk_live_your_magic_publishable_key

# Particle Universal Accounts
VITE_PROJECT_ID=your-particle-project-id
VITE_CLIENT_KEY=your-particle-client-key
VITE_APP_ID=your-particle-app-uuid

# RPC (Magick EIP-7702 needs these chains when converting cross-chain funds)
VITE_ARB_RPC_URL=https://arb1.arbitrum.io/rpc
# Ethereum RPC for Magick Type-4 unlock when converting Eth-mainnet funds
# VITE_ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# VITE_BASE_RPC_URL=https://base.gateway.tenderly.co

# PayGram contracts (Arbitrum One) — after `cd contracts && npm run deploy:arb && npm run env:app`
# Note: VITE_ROSCA must be the invite/accept/decline build (redeploy Rosca after that change).
VITE_PAYGRAM_NETWORK=arbitrum
VITE_USDC_ADDRESS=0xaf88d065e77c8cC2239327C5EDb3A432268e5831
VITE_POT=0x6D58560966914637565B4a10ebDADD56ea49E2cF
VITE_BILL_ESCROW=0xe927742DBfFa80Df2575B5220cc74d91459A86A8
VITE_ROSCA=0xd6aCb0ef288001c171FCA29300f001970B2e5a45
VITE_TAB=0xcfbb48A1C3890BB9a550d92A3dC0A02571B0A4bE
VITE_ALLOWANCE=0x1d19aD900A157d83982816B48f4452bD01eF8B7b

# Dev fallback — recipient when @username not in registry
VITE_DEMO_RECIPIENT_ADDRESS=0x

# API (optional — defaults to same origin on Vercel)
VITE_API_URL=

# Required for unique @usernames (Vercel Storage → Upstash Redis / KV)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Optional fiat on-ramp (defaults to MoonPay). Use {address} for the deposit wallet.
# VITE_ONRAMP_URL=https://buy.moonpay.com/?defaultCurrencyCode=usdc&walletAddress={address}

# Vercel KV / Upstash Redis (Vercel dashboard → Storage → Upstash Redis)
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Or Upstash-native names:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional — LLM parser fallback when regex fails (/api/parse-intent)
OPENAI_API_KEY=
